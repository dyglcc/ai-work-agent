# Debug profile: DeepSeek via OpenAI-compatible API.
#
# Usage:
#   Windows PowerShell:
#     Copy-Item .env.debug.example .env.debug
#     $env:AI_WORK_ENV="debug"; python run.py
#   macOS/Linux:
#     cp .env.debug.example .env.debug
#     AI_WORK_ENV=debug python run.py
#
# Fill in real keys locally. Do not commit .env.debug.

AI_WORK_AI_PROVIDER=openai
AI_WORK_OPENAI_API_KEY=your-deepseek-api-key
AI_WORK_OPENAI_BASE_URL=https://api.deepseek.com
AI_WORK_OPENAI_MODEL=deepseek-chat

# Anthropic-compatible online provider fallback.
AI_WORK_ANTHROPIC_API_KEY=
AI_WORK_ANTHROPIC_BASE_URL=
AI_WORK_CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional real image generation service. Leave empty to use local poster fallback.
# Example for OpenAI-compatible image APIs:
#   AI_WORK_IMAGE_API_URL=https://api.example.com/v1/images/generations
#   AI_WORK_IMAGE_API_KEY=your-image-api-key
#   AI_WORK_IMAGE_MODEL=dall-e-3
AI_WORK_IMAGE_API_URL=
AI_WORK_IMAGE_API_KEY=
AI_WORK_IMAGE_MODEL=dall-e-3

# Service
AI_WORK_HOST=127.0.0.1
AI_WORK_PORT=8000
AI_WORK_RELOAD=false
AI_WORK_LOG_LEVEL=DEBUG
AI_WORK_FILE_STORAGE_DIR=
AI_WORK_SKILLS_DIR=skills
AI_WORK_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Platform adapters
AI_WORK_DINGTALK_ENABLED=false
AI_WORK_DINGTALK_APP_KEY=your_app_key
AI_WORK_DINGTALK_APP_SECRET=your_app_secret

AI_WORK_FEISHU_ENABLED=false
AI_WORK_FEISHU_APP_ID=your_app_id
AI_WORK_FEISHU_APP_SECRET=your_app_secret
