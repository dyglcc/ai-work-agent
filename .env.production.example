# Production/online profile: Qwen via Anthropic-compatible gateway
#
# Usage:
#   Windows PowerShell:
#     Copy-Item .env.production.example .env
#   macOS/Linux:
#     cp .env.production.example .env
#
# Fill in the real online gateway key locally. Do not commit .env.

AI_WORK_AI_PROVIDER=anthropic
AI_WORK_ANTHROPIC_API_KEY=your-online-api-key
AI_WORK_ANTHROPIC_BASE_URL=https://ai-api.bingex.com/anthropic
AI_WORK_CLAUDE_MODEL=qwen3.6-plus

# OpenAI-compatible debug provider is disabled in production.
AI_WORK_OPENAI_API_KEY=
AI_WORK_OPENAI_BASE_URL=https://api.deepseek.com
AI_WORK_OPENAI_MODEL=deepseek-chat

# Optional real image generation service. Leave empty to use local poster fallback.
AI_WORK_IMAGE_API_URL=
AI_WORK_IMAGE_API_KEY=
AI_WORK_IMAGE_MODEL=dall-e-3

# Service
AI_WORK_HOST=0.0.0.0
AI_WORK_PORT=8000
AI_WORK_RELOAD=false
AI_WORK_LOG_LEVEL=INFO
AI_WORK_FILE_STORAGE_DIR=
AI_WORK_SKILLS_DIR=skills

# Platform adapters
AI_WORK_DINGTALK_ENABLED=false
AI_WORK_DINGTALK_APP_KEY=your_app_key
AI_WORK_DINGTALK_APP_SECRET=your_app_secret

AI_WORK_FEISHU_ENABLED=false
AI_WORK_FEISHU_APP_ID=your_app_id
AI_WORK_FEISHU_APP_SECRET=your_app_secret
